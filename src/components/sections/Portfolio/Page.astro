---
import bg from "@/assets/media/bg/PortfolioBg.png";
import HeaderText from "@/components/ui/HeaderText.astro";
import ListElements from "./CardElements.astro";
import { siteCopy, type Locale } from "@/content/i18n/site";

interface Props {
    locale?: Locale;
    basePath?: string;
}

const { locale = "es", basePath = "/" } = Astro.props;
const copy = siteCopy[locale];
---

<style define:vars={{ image: `url("${bg.src}")` }}>
    section {
        position: relative;
    }

    section::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        max-width: 100vw;
        width: 100%;
        height: 100%;

        z-index: -10;
        opacity: 0.4;
        filter: brightness(50%) contrast(120%);

        background-image: var(--image);
        background-position: 50% 50%;
        background-repeat: no-repeat;
    }
</style>

<section id="portfolio" class="text-white text-center ">
    <article
        class="container mx-auto mb-auto flex h-auto w-full max-w-[1200px] flex-col items-center justify-center px-6 md:px-10"
    >
        <div
            class="flex h-max w-full flex-col items-center gap-16 overflow-visible uppercase md:gap-20"
        >
            <HeaderText align="center">
                <h1 slot="title" class="uppercase">{copy.portfolio.title}</h1>
                <h3 slot="description">
                    {copy.portfolio.description}
                </h3>
            </HeaderText>

            <div class="flex justify-center">
                <a href={`${basePath}portafolio#tat`}>
                    <div
                        class="animate-bounce shadow-secondary shadow-2xl p-2 w-10 h-10 ring-1 ring-secondary rounded-full flex items-center justify-center"
                    >
                        <svg
                            class="w-6 h-6 text-violet-500"
                            fill="none"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                        </svg>
                    </div>
                </a>
            </div>
        </div>
    </article>

    <ListElements locale={locale} />
</section>
