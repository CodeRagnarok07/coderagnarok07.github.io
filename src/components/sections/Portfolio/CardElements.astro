---
import imgData from "@/assets/portfolio";
import DiviceSelector from "./DiviceSelector.astro";
import dataPortfolioEs from "@/content/i18n/es/PortFolio_Items.json";
import dataPortfolioPt from "@/content/i18n/pt/PortFolio_Items.json";
import dataPortfolioEn from "@/content/i18n/en/PortFolio_Items.json";
import Card from "@/components/ui/Card.astro";
import Btn from "@/components/ui/Btn.astro";
import type { Locale } from "@/content/i18n/site";

interface Props {
    locale?: Locale;
}

const { locale = "es" } = Astro.props;
const dataPortfolio =
    locale === "pt"
        ? dataPortfolioPt
        : locale === "en"
          ? dataPortfolioEn
          : dataPortfolioEs;

const sourceLabel = locale === "pt" ? "Código fonte" : locale === "en" ? "Source code" : "github";
const liveLabel =
    locale === "pt" ? "Ver online" : locale === "en" ? "View online" : "Ver en linea";
const detailLabel =
    locale === "pt" ? "Ver detalle" : locale === "en" ? "View details" : "Ver detalle";

const getImgsFromKey = (id: string): TypeGetImgsFromKey => {
    return imgData.filter((path) => path[0].includes(id));
};

const getDocUrl = (id: string): string => `/portfolio/${id.toLowerCase()}/`;
---

{
    dataPortfolio
        .filter((entry) => getImgsFromKey(entry.id).length > 0)
        .map((entry) => (
            <article id={entry.id}>
                <div class="container mx-auto flex w-full h-min ">
                    <Card
                        theme="secondary"
                        className={
                            "pb-5 px-10  h-full my-auto w-full md:py-20 p-4 md:p-8 rounded-md bg-black-dark bg-opacity-70 flex flex-col items-center md:flex-row"
                        }
                    >
                        <div class="relative z-10 w-full md:w-1/2 my-auto">
                            <DiviceSelector pathsList={getImgsFromKey(entry.id)} />
                        </div>
                        <div class="relative z-20 w-full md:w-1/2">
                            <h3 class="text-center">{entry.Title}</h3>
                            <div class="flex flex-wrap flex-row items-center w-full py-4 justify-center gap-4">
                                <a href={getDocUrl(entry.id)}>
                                    <Btn theme="primary">{detailLabel}</Btn>
                                </a>
                                {entry.github && (
                                    <a href={entry.github} target="_blank" rel="noopener noreferrer">
                                        <Btn theme="primary">{sourceLabel}</Btn>
                                    </a>
                                )}
                                {entry.live && (
                                    <a href={entry.live} target="_blank" rel="noopener noreferrer">
                                        <Btn theme="secondary">{liveLabel}</Btn>
                                    </a>
                                )}
                            </div>
                        </div>
                    </Card>
                </div>
            </article>
        ))
}
