---
import services from "@/content/i18n/es/services.json";
import bg from "@/assets/media/bg/bg-skills.png";
import HeaderText from "../ui/HeaderText.astro";
---

<style define:vars={{ image: `url("${bg.src}")` }}>
    article {
        position: relative;
        z-index: 20;
    }
    article::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        max-width: 100vw;
        width: 100%;
        height: 100%;

        z-index: -10;
        opacity: 0.4;
        filter: brightness(50%) contrast(150%);

        background-image: var(--image);
        background-position: 50% 10%;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }
</style>

<article id="services" class="relative text-white">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
        <HeaderText align="left" className="mb-8 md:mb-12">
            <h1 slot="title" class="">{services.CTA.p}</h1>
            <h4 slot="description">{services.CTA.r}</h4>
        </HeaderText>

        <div
            class="grid w-full grid-cols-1 gap-4 pb-10 sm:grid-cols-3 md:gap-6"
        >
            {
                services.items.map((v) => (
                    <a href="#contact" class="no-underline">
                        <div
                            class="rounded-md border border-blue bg-black-dark bg-opacity-20 text-white shadow-blue transition-all duration-500 hover:shadow-[0px_0px_30px_0px] hover:shadow-blue 
                        p-4
                        md:p-6"
                        >
                            <h4 class="mb-4">{v.title}</h4>

                            {v.content}
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</article>
