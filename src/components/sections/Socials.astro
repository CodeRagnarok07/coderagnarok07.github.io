---
import Icon from "@/assets/Icon.astro";
import HeaderText from "../ui/HeaderText.astro";
import bg from "@/assets/media/bg/bg1.png";
import { socialLinks } from "@/content/consts";
import { siteCopy, type Locale } from "@/content/i18n/site";

interface Props {
    locale?: Locale;
}

const { locale = "es" } = Astro.props;
const copy = siteCopy[locale];
---

<article id="contact">
    <div
        class="content-shell min-h-[50vh] justify-items-center
        h-[80vh]
        flex flex-col items-center justify-center"
    >
        <HeaderText align="center" className="mb-8 ">
            <h1 slot="title" class="">
                {copy.contact.title}
            </h1>
            <h4 slot="description">
                {copy.contact.description}
            </h4>
        </HeaderText>

        <div class="flex flex-wrap items-center justify-center gap-4">
            {
                socialLinks.map((v) => (
                    <a
                        target="_blank"
                        rel="noopener noreferrer"
                        href={v.link}
                        aria-label={v.name}
                    >
                        <div class="flex size-12 items-center justify-center rounded-full border border-blue bg-black-dark bg-opacity-40 p-2 shadow-[0px_0px_12px_0px] shadow-blue transition-shadow duration-300 hover:shadow-[0px_0px_18px_0px] hover:shadow-blue sm:size-14">
                            <Icon icon={v.icon} />
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</article>

<style define:vars={{ image: `url("${bg.src}")` }}>
    article {
        position: relative;
        z-index: 20;
    }
    article::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        max-width: 100vw;
        width: 100%;
        height: 100%;

        z-index: -10;
        opacity: 0.4;
        filter: brightness(150%) contrast(150%);
        background:
            linear-gradient(rgb(0 0 0 / 64%), rgb(0 0 0 / 0%)), var(--image);
        /* box-shadow: inset 0px -2rem 15rem 2rem rgb(0 0 0); */
        background-position: 50% 50%;
        background-repeat: no-repeat;
        /* background-attachment: fixed; */
        background-size: 100%;
    }
</style>
