---
let data = {
    name: "",
    description: "",
};

// const setData = (data: string) => {
//     console.log(data);
// };

type size = "sm" | "md";
const { size: size = "sm" } = Astro.props;
---

<style>
    textarea,
    input {
        background-color: transparent;
        width: 100%;
        height: 100%;
        padding: 0;
        margin: 0;
    }
    textarea:focus-visible,
    input:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 2px;
    }
    form {
      
    }
</style>

<div  class="w-full flex justify-center">
    <form
        class={`w-full border-box-primary border-sm p-6 rounded-lg gap-4 flex flex-col bg-black-dark`}
    >
        <label for="contact-name" class="sr-only">Tu nombre</label>
        <input
            name="name"
            id="contact-name"
            placeholder="Tu nombre"
            class="w-full btn border-box-primary border-sm h-min"
            type="text"
            autocomplete="name"
        />
        <!-- <input
            placeholder="Correo"
            class="hidden md:flex w-full btn border-box-primary border-sm"
            type="text"
            id=""
        /> -->

        <label for="contact-description" class="sr-only">Preguntas o sugerencias</label>
        <textarea
            id="contact-description"
            placeholder="Preguntas o sugerencias"
            class="w-full h-full btn border-box-primary border-sm"
            name="description"
            rows="5"></textarea>

        <div class="flex flex-col items-center justify-center">
            <button
                type="submit"
                class="btn btn-secondary border-box-secondary mx-auto w-min"
            >
                Enviar
            </button>
            <!-- <a href={`Hola mi nombre es ${data.name} \n \n ${data.description}`}
                    target="_blank"
                    class="btn border-secondary">Enviar</a
                > -->
        </div>
    </form>
</div>
