---
interface Props {
    align?: "left" | "center" | "right";
    className?: string;
}

const { align = "center", className = "" } = Astro.props;

const alignClassMap = {
    left: "items-start text-left",
    center: "items-center text-center",
    right: "items-end text-right",
};
---

<style>
    .section-header {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }
    .title-wrap {
        width: fit-content;
        max-width: 100%;
        display: inline-flex;
        flex-direction: column;
        gap: 0.65rem;
    }
    .divider {
        width: 100%;
        min-width: 8rem;
    }
    .section-header :global(h1),
    .section-header :global(h2),
    .section-header :global(h3),
    .section-header :global(h4) {
        margin: 0;
        line-height: 1.2;
    }
    .section-header :global(p) {
        margin: 0;
    }
    @media (max-width: 575px) {
        .section-header {
            text-align: center;
            align-items: center;
        }
    }
</style>

<header class:list={["section-header", alignClassMap[align], className]}>
    <div class="title-wrap">
        <slot name="title" />

        <svg
            class="divider"
            height="1"
            viewBox="0 0 790 2"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path d="M395 0L673.954 0.292893L789.5 1L673.954 1.70711L395 2L116.046 1.70711L0.5 1L116.046 0.292893L395 0Z" fill="#D3D3D3"/>
        </svg>
    </div>

    <slot name="description" />
</header>
