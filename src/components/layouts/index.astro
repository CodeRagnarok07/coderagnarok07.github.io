---
import BaseHead from "@/components/layouts/BaseHead.astro";
import Navbar from "@/components/layouts/Navbar/index.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "@/content/consts";
---

<html lang="en" class="dark">
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <body class="bg-[#030713] text-white leading-normal min-h-dvh">
        <a href="#main-content" class="skip-link">
            Saltar al contenido
        </a>
        <Navbar />

        <main id="main-content">
            <slot />
        </main>

        <!-- <Footer /> -->
        <style is:global>
            @import "tailwindcss";
            html {
                min-height: 100dvh;
                color-scheme: dark;
            }
            body {
                min-height: 100dvh;
                position: relative;
            }
            a {
                text-decoration: none !important;
            }
            a:focus-visible,
            button:focus-visible {
                outline: 2px solid currentColor;
                outline-offset: 2px;
            }
            [id] {
                scroll-margin-top: 6rem;
            }
            .skip-link {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }
            .skip-link:focus {
                position: fixed;
                top: 1rem;
                left: 1rem;
                z-index: 1001;
                width: auto;
                height: auto;
                padding: 0.5rem 1rem;
                margin: 0;
                overflow: visible;
                clip: auto;
                white-space: normal;
                background: white;
                color: #030713;
                border-radius: 0.375rem;
            }
            @media (prefers-reduced-motion: reduce) {
                *, *::before, *::after {
                    animation-duration: 0.01ms !important;
                    animation-iteration-count: 1 !important;
                }
                /* Do not override transition-duration globally: it can break scroll in some browsers */
            }
            .container {
                margin: 0 auto;
                min-width: 100%;
            }
            /* Desktop: landing page — main scrolls vertically. Mobile: finger slider — main scrolls horizontally, section scrolls vertically. */
            main {
                position: absolute;
                inset: 0;
                min-height: 100dvh;
                display: flex;
                flex-wrap: nowrap;
                overflow-x: auto;
                overflow-y: hidden;
                scroll-behavior: smooth;
                scroll-snap-type: x mandatory;
                -ms-overflow-style: none;
                scrollbar-width: none;
                -webkit-overflow-scrolling: touch;
                @apply flex-row md:flex-col md:snap-y md:snap-mandatory md:overflow-x-hidden md:overflow-y-auto;

                & > section {
                    position: relative;
                    height: 100%;
                    min-height: 100dvh;
                    overflow-x: hidden;
                    overflow-y: auto;
                    -webkit-overflow-scrolling: touch;
                    overscroll-behavior-y: auto;

                    width: 100%;
                    max-width: 100dvw;
                    flex: 0 0 100%;

                    display: flex;
                    flex-shrink: 0;
                    scroll-snap-align: start;
                    scroll-snap-stop: always;
                    flex-direction: column;
                    scroll-snap-type: y mandatory;

                    -ms-overflow-style: none;
                    scrollbar-width: none;

                    & > article {
                        min-height: 100dvh;
                        width: 100dvw;
                        max-width: 100dvw;
                        scroll-snap-align: center;
                        scroll-snap-stop: always;
                        overflow: hidden;
                        overflow-y: auto;
                        -webkit-overflow-scrolling: touch;

                        padding-bottom: 24%;
                        @apply pt-4 sm:pt-24 md:pt-28 sm:pb-0 sm:overflow-y-hidden;
                    }
                }
            }
            main::-webkit-scrollbar,
            main > section::-webkit-scrollbar,
            main > section > article::-webkit-scrollbar {
                /* Hide scrollbar for Chrome, Safari and Opera */
                display: none;
            }
        </style>
    </body>
</html>
